# Supabase (obter em Settings > API no dashboard do Supabase)
SUPABASE_URL=https://seu-projecto.supabase.co
SUPABASE_KEY=seu_service_role_key_aqui

# OTP Configuration
OTP_EXPIRATION_MINUTES=20
MAX_ATTEMPTS=3

# Server
PORT=3000
ADMIN_USER=admin
ADMIN_PASS=mude_para_senha_forte

# Resend (Email API)
RESEND_API_KEY=re_sua-chave-aqui
EMAIL_FROM=Seu Nome <seu-email@dominio.com>
