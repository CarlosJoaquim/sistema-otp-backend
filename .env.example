# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key

# Resend (Email API)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=CAOP-B <team@caop-b.com>

# Admin Credentials (CHANGE THESE FOR PRODUCTION!)
ADMIN_USER=admin
ADMIN_PASS=CHANGE_THIS_TO_A_STRONG_PASSWORD

# OTP Configuration
OTP_EXPIRATION_MINUTES=20
MAX_ATTEMPTS=3

# Redis (Optional - for distributed rate limiting)
# Leave empty or use localhost for development
REDIS_URL=

# CORS - Allowed Origins (comma-separated, use * for all)
ALLOWED_ORIGINS=https://your-domain.com

# For Next.js (leave empty for same domain)
NEXT_PUBLIC_API_URL=

# Cron job secret (for cleanup endpoint)
CRON_SECRET=generate_a_random_secret_here

# Environment
NODE_ENV=production
